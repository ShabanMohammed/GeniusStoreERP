<UserControl x:Class="GeniusStoreERP.UI.Views.Users.UserManagementListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:GeniusStoreERP.UI.ViewModels.Users"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Section: Header & Actions -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="إدارة المستخدمين"
                       Style="{StaticResource MainHeaderStyle}"
                       FontSize="28"
                       Grid.Column="0"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <!-- Search Bar -->
                <Border Style="{StaticResource UnifiedInputContainerStyle}"
                        Width="300"
                        Margin="0,0,15,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Viewbox Width="18" Height="18" Margin="10,0,0,0">
                            <Path Data="{StaticResource IconSearch}" Fill="#95A5A6" Stretch="Uniform"/>
                        </Viewbox>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource UnifiedTextBoxStyle}"
                                 Tag="بحث عن مستخدم..."/>
                    </Grid>
                </Border>

                <!-- Add Button -->
                <Button Command="{Binding AddCommand}"
                        Style="{StaticResource UnifiedPrimaryButtonStyle}"
                        Width="180"
                        ToolTip="إضافة مستخدم جديد">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                            <Path Data="{StaticResource IconAdd}" Fill="White" Stretch="Uniform"/>
                        </Viewbox>
                        <TextBlock Text="إضافة مستخدم جديد" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Center Section: DataGrid Area -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Effect="{StaticResource UnifiedCardStyle_ShadowOnly}">
            <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding EditCommand}"
                                  CommandParameter="{Binding SelectedUser}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="الاسم الكامل" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="اسم المستخدم" Binding="{Binding UserName}" Width="*"/>
                    <DataGridTextColumn Header="البريد الإلكتروني" Binding="{Binding Email}" Width="*"/>
                    <DataGridTemplateColumn Header="الدور" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="Admin">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="Sales">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="Warehouse">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                    <Setter Property="BorderBrush" Value="#FF9800"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="Accountant">
                                                    <Setter Property="Background" Value="#F3E5F5"/>
                                                    <Setter Property="BorderBrush" Value="#9C27B0"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Role}" FontWeight="SemiBold" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="Admin">
                                                        <Setter Property="Foreground" Value="#1565C0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="Sales">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="Warehouse">
                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="Accountant">
                                                        <Setter Property="Foreground" Value="#7B1FA2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="الإجراءات" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0" Margin="0,0,10,0" ToolTip="تعديل">
                                        <Viewbox Width="18" Height="18">
                                            <Path Data="{StaticResource IconEdit}" Fill="{StaticResource AccentActionBrush}" Stretch="Uniform"/>
                                        </Viewbox>
                                    </Button>
                                    <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0" ToolTip="حذف">
                                        <Viewbox Width="18" Height="18">
                                            <Path Data="{StaticResource IconDelete}" Fill="#E74C3C" Stretch="Uniform"/>
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Bottom Section: Pagination -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" Foreground="#7F8C8D">
                 <Run Text="عرض القيمة "/>
                 <Run Text="{Binding Users.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                 <Run Text=" من إجمالي "/>
                 <Run Text="{Binding TotalItems}" FontWeight="SemiBold"/>
                 <Run Text=" عنصر"/>
            </TextBlock>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Command="{Binding PreviousPageCommand}" Style="{StaticResource UnifiedPrimaryButtonStyle}" Width="40" Height="35" ToolTip="الصفحة السابقة">
                    <Viewbox Width="18" Height="18">
                        <Path Data="{StaticResource IconPreviousPage}" Fill="White" Stretch="Uniform"/>
                    </Viewbox>
                </Button>
                <Border Background="#F1F3F5" CornerRadius="5" Padding="15,0" Margin="5,0">
                     <TextBlock VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold">
                         <Run Text="صفحة "/>
                         <Run Text="{Binding CurrentPage}"/>
                         <Run Text=" من "/>
                         <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                     </TextBlock>
                </Border>
                <Button Command="{Binding NextPageCommand}" Style="{StaticResource UnifiedPrimaryButtonStyle}" Width="40" Height="35" ToolTip="الصفحة التالية">
                    <Viewbox Width="18" Height="18">
                        <Path Data="{StaticResource IconNextPage}" Fill="White" Stretch="Uniform"/>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
