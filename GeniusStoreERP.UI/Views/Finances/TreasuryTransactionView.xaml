<UserControl x:Class="GeniusStoreERP.UI.Views.Finances.TreasuryTransactionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GeniusStoreERP.UI.Views.Finances"
             mc:Ignorable="d" 
             FlowDirection="RightToLeft"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="15" Background="{StaticResource PrimaryHeaderBrush}" CornerRadius="10" Margin="0,0,0,20">
            <TextBlock Text="إضافة حركة خزينة (سند قبض / صرف)" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <!-- Form Card -->
        <Border Grid.Row="1" Style="{StaticResource UnifiedCardStyle}" VerticalAlignment="Top" MaxWidth="600" Padding="20">
            <StackPanel>
                <!-- Treasury Info (ReadOnly) -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="الخزينة" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding TreasuryName}" IsReadOnly="True" Background="#F1F3F5" Height="35" VerticalContentAlignment="Center" FontWeight="Bold"/>
                </StackPanel>

                <!-- Transaction Type (Radio Buttons) -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="نوع الحركة" Style="{StaticResource FieldLabelStyle}"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="إيداع / قبض (+)" IsChecked="{Binding Type, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=CashIn}" Margin="0,0,20,0" FontSize="14" FontWeight="SemiBold" Foreground="#27AE60"/>
                        <RadioButton Content="سحب / صرف (-)" IsChecked="{Binding Type, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=CashOut}" FontSize="14" FontWeight="SemiBold" Foreground="#E74C3C"/>
                    </StackPanel>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Amount -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="المبلغ" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" FontSize="18" FontWeight="Bold" Height="40" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Date -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,15">
                        <TextBlock Text="التاريخ" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding TransactionDate}" Height="40" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Partner selection -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="الشريك (اختياري)" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Partners}" 
                              SelectedItem="{Binding SelectedPartner}"
                              DisplayMemberPath="Name"
                              Height="35"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              TextSearch.TextPath="Name"/>
                    <TextBlock Text="* سيتم تحديث رصيد الشريك تلقائياً عند الحفظ" FontSize="11" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Reference Number -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="رقم المرجع / السند" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding ReferenceNumber}" Height="35" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Notes -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="ملاحظات" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding Notes}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <Border Grid.Row="2" Padding="10" Background="#F8F9FA" CornerRadius="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding SaveCommand}" Content="حفظ العملية" Style="{StaticResource UnifiedPrimaryButtonStyle}" Width="150" Height="40" Margin="10,0" Background="#27AE60"/>
                <Button Command="{Binding CancelCommand}" Content="إلغاء / رجوع" Style="{StaticResource UnifiedPrimaryButtonStyle}" Width="150" Height="40" Margin="10,0" Background="#E74C3C"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
