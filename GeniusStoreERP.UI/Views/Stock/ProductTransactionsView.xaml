<UserControl x:Class="GeniusStoreERP.UI.Views.ProductTransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header & Filters -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
            <RowDefinition Height="Auto"/> <!-- Pagination -->
        </Grid.RowDefinitions>

        <!-- Top Section: Header & Filters -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title and Back Button -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding BackCommand}"
                        Style="{StaticResource UnifiedSecondaryButtonStyle}"
                        Margin="0,0,15,0"
                        Width="40" Height="40"
                        ToolTip="رجوع">
                    <Viewbox Width="16" Height="16">
                        <Path Data="{StaticResource IconBack}" Fill="{StaticResource MainContentTextBrush}" Stretch="Uniform"/>
                    </Viewbox>
                </Button>
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource MainHeaderStyle}"
                           FontSize="28"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Filters -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="من:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}" 
                            Width="150" Margin="0,0,15,0"/>
                
                <TextBlock Text="إلى:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker SelectedDate="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}" 
                            Width="150" Margin="0,0,15,0"/>

                <Button Command="{Binding ClearDatesCommand}"
                        Style="{StaticResource UnifiedSecondaryButtonStyle}"
                        Width="100"
                        Margin="0,0,10,0"
                        Content="مسح الفلتر" />
                
                <Button Command="{Binding PrintReportCommand}"
                        Style="{StaticResource UnifiedPrimaryButtonStyle}"
                        Width="100"
                        Content="طباعة التقرير">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                    <Path Data="{StaticResource IconPrint}" Fill="White" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBlock Text="طباعة"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Center Section: DataGrid Area -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Effect="{StaticResource UnifiedCardStyle_ShadowOnly}">
            <DataGrid ItemsSource="{Binding Transactions}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="رقم الحركة" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="تاريخ الحركة" Binding="{Binding TransactionDate, StringFormat=\{0:yyyy/MM/dd HH:mm\}}" Width="150"/>
                    <DataGridTextColumn Header="نوع الحركة" Binding="{Binding StockTransactionTypeName}" Width="150"/>
                    <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="100"/>
                    <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceReference}" Width="120"/>
                    <DataGridTextColumn Header="رقم التسوية" Binding="{Binding AdjustmentReference}" Width="120"/>
                    <DataGridTextColumn Header="ملاحظات" Binding="{Binding Remarks}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Bottom Section: Pagination -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Page Size Selector -->
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock Text="عرض" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="{StaticResource FontSizeSmall}" Foreground="#7F8C8D"/>
                <Border Style="{StaticResource UnifiedInputContainerStyle}" Height="35" Margin="0" Padding="2">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding DecreasePageSizeCommand}" Content="-" Width="25" Background="Transparent" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                        <TextBox Text="{Binding PageSize}" IsReadOnly="True" Width="30" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="0"/>
                        <Button Command="{Binding IncreasePageSizeCommand}" Content="+" Width="25" Background="Transparent" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="عناصر لكل صفحة" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="{StaticResource FontSizeSmall}" Foreground="#7F8C8D"/>
            </StackPanel>

            <!-- Summary Text -->
            <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeSmall}" Foreground="#7F8C8D">
                <Run Text="عرض القيمة "/>
                <Run Text="{Binding Transactions.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                <Run Text=" من إجمالي "/>
                <Run Text="{Binding TotalItems}" FontWeight="SemiBold"/>
                <Run Text=" عنصر"/>
            </TextBlock>

            <!-- Navigation Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Command="{Binding FirstPageCommand}" Style="{StaticResource UnifiedPrimaryButtonStyle}" Width="40" Height="35" Padding="0" Margin="0,0,5,0" ToolTip="الصفحة الأولى">
                    <Viewbox Width="18" Height="18"><Path Data="{StaticResource IconFirstPage}" Fill="White" Stretch="Uniform"/></Viewbox>
                </Button>
                <Button Command="{Binding PreviousPageCommand}" Style="{StaticResource UnifiedPrimaryButtonStyle}" Width="40" Height="35" Padding="0" ToolTip="الصفحة السابقة">
                    <Viewbox Width="18" Height="18"><Path Data="{StaticResource IconPreviousPage}" Fill="White" Stretch="Uniform"/></Viewbox>
                </Button>
                <Border Background="#F1F3F5" CornerRadius="5" Padding="15,0" Margin="5,0">
                    <TextBlock VerticalAlignment="Center" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold">
                        <Run Text="صفحة"/><Run Text=" "/><Run Text="{Binding CurrentPage}"/><Run Text=" "/><Run Text="من"/><Run Text=" "/><Run Text="{Binding TotalPages, Mode=OneWay}"/>
                    </TextBlock>
                </Border>
                <Button Command="{Binding NextPageCommand}" Style="{StaticResource UnifiedPrimaryButtonStyle}" Width="40" Height="35" Padding="0" ToolTip="الصفحة التالية">
                    <Viewbox Width="18" Height="18"><Path Data="{StaticResource IconNextPage}" Fill="White" Stretch="Uniform"/></Viewbox>
                </Button>
                <Button Command="{Binding LastPageCommand}" Style="{StaticResource UnifiedPrimaryButtonStyle}" Width="40" Height="35" Padding="0" Margin="5,0,0,0" ToolTip="الصفحة الأخيرة">
                    <Viewbox Width="18" Height="18"><Path Data="{StaticResource IconLastPage}" Fill="White" Stretch="Uniform"/></Viewbox>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
