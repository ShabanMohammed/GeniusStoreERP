<UserControl x:Class="GeniusStoreERP.UI.Views.Stock.StockAdjustmentEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="15" Background="{StaticResource PrimaryHeaderBrush}" CornerRadius="10" Margin="0,0,0,20">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="{StaticResource FontSizeLarge}" FontWeight="Bold"/>
                    <Border Margin="15,0,0,0" Padding="10,3" CornerRadius="12" 
                            Background="#E8F5E9"
                            Visibility="{Binding IsViewMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="عرض فقط" Foreground="#2E7D32" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" DockPanel.Dock="Left">
                    <Button Command="{Binding SaveCommand}" Content="حفظ (F10)" 
                            Visibility="{Binding IsViewMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            Style="{StaticResource UnifiedPrimaryButtonStyle}" Background="#27ae60" Margin="5,0" Padding="15,0"/>
                    <Button Command="{Binding BackCommand}" Content="رجوع" Style="{StaticResource UnifiedPrimaryButtonStyle}" Background="#e74c3c" Margin="5,0" Padding="15,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Basic Info Box -->
        <Border Grid.Row="1" Style="{StaticResource UnifiedCardStyle}" Margin="0,0,0,20">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="تاريخ التسوية" Style="{StaticResource FieldLabelStyle}"/>
                    <DatePicker SelectedDate="{Binding AdjustmentDate}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBooleanConverter}}" Height="35" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="رقم المرجع" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding ReferenceNumber}" IsReadOnly="True" Height="35" Background="#F1F5F9" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="ملاحظات" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding Remarks}" IsReadOnly="{Binding IsViewMode}" Height="35" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Items Table Area -->
        <Border Grid.Row="2" Style="{StaticResource UnifiedCardStyle}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Item Entry Bar -->
                <Border Grid.Row="0" Background="#f8f9fa" CornerRadius="5" Padding="10" Margin="0,0,0,10"
                        Visibility="{Binding IsViewMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="الصنف" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <ComboBox ItemsSource="{Binding Products}"
                                      SelectedItem="{Binding SelectedProduct}"
                                      DisplayMemberPath="Name"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      TextSearch.TextPath="Name"
                                      Height="30" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0">
                            <TextBlock Text="الرصيد الحالي" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CurrentItem.PreviousQuantity, Mode=OneWay}" IsReadOnly="True" Height="30" VerticalContentAlignment="Center" Background="#F1F5F9"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="5,0">
                            <TextBlock Text="مقدار التغيير (+/-)" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CurrentItem.QuantityChange, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="5,0">
                            <TextBlock Text="نوع الحركة" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <ComboBox ItemsSource="{Binding TransactionTypes}" 
                                      SelectedItem="{Binding CurrentItem.SelectedTransactionType}"
                                      DisplayMemberPath="Name" Height="30"/>
                        </StackPanel>

                        <Button Grid.Column="4" Command="{Binding AddItemCommand}" Content="إضافة" 
                                Style="{StaticResource UnifiedPrimaryButtonStyle}" Background="{StaticResource AccentActionBrush}" 
                                Height="30" Padding="15,0" Margin="10,0,0,0" VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>

                <!-- Items Grid -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="اسم الصنف" Binding="{Binding ProductName}" Width="2*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="الرصيد السابق" Binding="{Binding PreviousQuantity}" Width="*" IsReadOnly="True"/>
                        
                        <DataGridTemplateColumn Header="مقدار التغيير" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding QuantityChange}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding QuantityChange, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding DataContext.IsViewMode, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="الرصيد الجديد" Binding="{Binding NewQuantity}" Width="*"/>
                        <DataGridTextColumn Header="نوع الحركة" Binding="{Binding SelectedTransactionType.Name}" Width="*"/>

                        <DataGridTemplateColumn Width="50" Visibility="{Binding DataContext.IsViewMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="🗑" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="16"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Totals Bar -->
        <Border Grid.Row="3" Margin="0,20,0,0" Padding="15" Background="#f8f9fa" CornerRadius="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <StackPanel Margin="20,0">
                    <TextBlock Text="إجمالي الأصناف" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d"/>
                    <TextBlock Text="{Binding Items.Count}" FontSize="{StaticResource FontSizeMedium}" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Margin="20,0">
                    <TextBlock Text="صافي تغيير الكمية" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d"/>
                    <TextBlock Text="{Binding TotalQuantityChange, StringFormat=\{0:N2\}}" FontSize="{StaticResource FontSizeLarge}" FontWeight="Bold" Foreground="{StaticResource PrimaryHeaderBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
