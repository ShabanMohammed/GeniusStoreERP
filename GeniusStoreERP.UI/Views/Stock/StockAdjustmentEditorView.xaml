<UserControl x:Class="GeniusStoreERP.UI.Views.Stock.StockAdjustmentEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Info & Search -->
            <RowDefinition Height="*"/>    <!-- Area -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding BackCommand}" Style="{StaticResource UnifiedSecondaryButtonStyle}" Margin="0,0,15,0" Width="40" Height="40" ToolTip="رجوع">
                    <Viewbox Width="16" Height="16"><Path Data="{StaticResource IconBack}" Fill="{StaticResource MainContentTextBrush}" Stretch="Uniform"/></Viewbox>
                </Button>
                <TextBlock Text="{Binding Title}" Style="{StaticResource MainHeaderStyle}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Basic Info & Search Box -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20" Effect="{StaticResource UnifiedCardStyle_ShadowOnly}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top Row: Date, Ref, Remarks -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="تاريخ التسوية" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource UnifiedInputContainerStyle}">
                            <DatePicker SelectedDate="{Binding AdjustmentDate}" IsEnabled="{Binding IsViewMode, Converter={StaticResource InverseBooleanConverter}}" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="5"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="رقم المرجع (تلقائي)" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource UnifiedInputContainerStyle}" Background="#F8FAFC">
                            <TextBox Text="{Binding ReferenceNumber}" IsReadOnly="True" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Foreground="#94A3B8"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="ملاحظات" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource UnifiedInputContainerStyle}">
                            <TextBox Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsViewMode}" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" MaxLength="500"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Bottom Row: Product Search (Only active in Edit mode) -->
                <StackPanel Grid.Row="1" Visibility="{Binding IsViewMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <TextBlock Text="البحث عن صنف لإضافته للتسوية:" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <Border Style="{StaticResource UnifiedInputContainerStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="18" Height="18" Margin="10,0">
                                    <Path Data="{StaticResource IconSearch}" Fill="#94A3B8" Stretch="Uniform"/>
                                </Viewbox>
                                <TextBox Grid.Column="1" 
                                         Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                                         Tag="ابحث باسم الصنف أو الكود (اكتب حرفين على الأقل)...">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="TextChanged">
                                            <i:InvokeCommandAction Command="{Binding SearchProductCommand}"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </TextBox>
                            </Grid>
                        </Border>

                        <Popup IsOpen="{Binding SearchResults.Count, Mode=OneWay, Converter={StaticResource GreaterThanZeroToBooleanConverter}}" AllowsTransparency="True" StaysOpen="False" Placement="Bottom" MinWidth="400">
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,5,0,0" Effect="{StaticResource UnifiedCardStyle_ShadowOnly}" MaxHeight="300">
                                <ListBox ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedProduct, Mode=TwoWay}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="5,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource MainContentTextBrush}"/>
                                                    <TextBlock Text="{Binding CategoryName}" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="#10B981" FontWeight="SemiBold" Margin="10,0,0,0">
                                                    <Run Text="الرصيد: "/>
                                                    <Run Text="{Binding StockQuantity, StringFormat=\{0:N2\}}"/>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Grid Area -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Effect="{StaticResource UnifiedCardStyle_ShadowOnly}">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="اسم الصنف" Binding="{Binding ProductName}" Width="2*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="الرصيد الحالي" Binding="{Binding PreviousQuantity, StringFormat=\{0:N2\}}" Width="1*" IsReadOnly="True"/>
                    
                    <!-- Editable Quantity Change -->
                    <DataGridTemplateColumn Header="مقدار التغيير (+/-)" Width="1.5*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding QuantityChange, StringFormat=\{0:N2\}}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding QuantityChange, UpdateSourceTrigger=PropertyChanged}" 
                                         IsEnabled="{Binding DataContext.IsViewMode, Converter={StaticResource InverseBooleanConverter}, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="الرصيد الجديد" Binding="{Binding NewQuantity, StringFormat=\{0:N2\}}" Width="1*" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#3B82F6"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Type Selection -->
                    <DataGridTemplateColumn Header="نوع الحركة" Width="1.5*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SelectedTransactionType.Name}" VerticalAlignment="Center" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.TransactionTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding SelectedTransactionType, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="Name"
                                          IsEnabled="{Binding DataContext.IsViewMode, Converter={StaticResource InverseBooleanConverter}, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTemplateColumn Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="حذف"
                                        Visibility="{Binding DataContext.IsViewMode, Converter={StaticResource InverseBooleanToVisibilityConverter}, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <Viewbox Width="16" Height="16"><Path Data="{StaticResource IconDelete}" Fill="#EF4444" Stretch="Uniform"/></Viewbox>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Save Button -->
        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Button Command="{Binding SaveCommand}" Style="{StaticResource UnifiedPrimaryButtonStyle}" Content="حفظ وتأكيد التسوية" Width="200" Height="45" HorizontalAlignment="Right"
                    Visibility="{Binding IsViewMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
        </Grid>

    </Grid>
</UserControl>
