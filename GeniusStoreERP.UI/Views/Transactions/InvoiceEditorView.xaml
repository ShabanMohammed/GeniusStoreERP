<UserControl x:Class="GeniusStoreERP.UI.Views.Transactions.InvoiceEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GeniusStoreERP.UI.Views.Transactions"
             mc:Ignorable="d" 
             FlowDirection="RightToLeft"
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="15" Background="{StaticResource PrimaryHeaderBrush}" CornerRadius="10" Margin="0,0,0,20">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="تحرير الفاتورة" Foreground="White" FontSize="{StaticResource FontSizeLarge}" FontWeight="Bold"/>
                    <Border Margin="15,0,0,0" Padding="10,3" CornerRadius="12" 
                            Visibility="{Binding IsReadOnly, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InvoiceStatusId}" Value="1">
                                        <Setter Property="Background" Value="#E8F5E9"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding InvoiceStatusId}" Value="2">
                                        <Setter Property="Background" Value="#FFEBEE"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Status}" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding InvoiceStatusId}" Value="1">
                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding InvoiceStatusId}" Value="2">
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" DockPanel.Dock="Left">
                    <Button Command="{Binding SaveCommand}" Content="حفظ (F10)" 
                            Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource UnifiedPrimaryButtonStyle}" Background="#27ae60" Margin="5,0" Padding="15,0"/>
                    <Button Command="{Binding CancelCommand}" Content="رجوع" Style="{StaticResource UnifiedPrimaryButtonStyle}" Background="#e74c3c" Margin="5,0" Padding="15,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Invoice Info -->
        <Border Grid.Row="1" Style="{StaticResource UnifiedCardStyle}" Margin="0,0,0,20">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="تاريخ الفاتورة" Style="{StaticResource FieldLabelStyle}"/>
                    <DatePicker SelectedDate="{Binding InvoiceDate}" IsEnabled="{Binding IsEditable}" Height="35" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="العميل / المورد" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Partners}" 
                               SelectedItem="{Binding SelectedPartner}"
                               IsEnabled="{Binding IsEditable}"
                               DisplayMemberPath="Name"
                               Height="35"
                               IsEditable="True"
                               IsTextSearchEnabled="True"
                               TextSearch.TextPath="Name"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="ملاحظات" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding Notes}" IsReadOnly="{Binding IsReadOnly}" Height="35"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Items Table -->
        <Border Grid.Row="2" Style="{StaticResource UnifiedCardStyle}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Item Entry Bar -->
                <Border Grid.Row="0" Background="#f8f9fa" CornerRadius="5" Padding="10" Margin="0,0,0,10"
                        Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="المنتج" FontSize="{StaticResource FontSizeNormal}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <ComboBox ItemsSource="{Binding Products}"
                                      SelectedItem="{Binding SelectedProduct}"
                                      DisplayMemberPath="Name"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      TextSearch.TextPath="Name"
                                      Height="30" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0">
                            <TextBlock Text="الكمية" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CurrentItem.Quantity, UpdateSourceTrigger=LostFocus}" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="5,0">
                            <TextBlock Text="السعر" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CurrentItem.UnitPrice, UpdateSourceTrigger=LostFocus}" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="5,0">
                            <TextBlock Text="خصم %" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CurrentItem.DiscountPercentage, UpdateSourceTrigger=LostFocus}" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="5,0">
                            <TextBlock Text="خصم مبلغ" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CurrentItem.DiscountAmount, UpdateSourceTrigger=LostFocus}" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="5" Margin="5,0">
                            <TextBlock Text="ضريبة %" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CurrentItem.TaxPercentage, UpdateSourceTrigger=LostFocus}" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6" Margin="5,0">
                            <TextBlock Text="ضريبة مبلغ" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CurrentItem.TaxAmount, UpdateSourceTrigger=LostFocus}" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="7" Margin="5,0">
                            <TextBlock Text="احمالى مبلغ" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CurrentItem.LineTotal, Mode=OneWay}" IsReadOnly="True" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="8" Command="{Binding AddItemCommand}" Content="إضافة" 
                                Style="{StaticResource UnifiedPrimaryButtonStyle}" 
                                Background="{StaticResource AccentActionBrush}" Height="30" Padding="15,0" Width="60" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- DataGrid (Read-Only) -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding InvoiceItems}" 
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          HeadersVisibility="Column" SelectionMode="Single"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="2*"/>
                        <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="*"/>
                        <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPrice}" Width="*"/>
                        <DataGridTextColumn Header="خصم %" Binding="{Binding DiscountPercentage}" Width="*"/>
                        <DataGridTextColumn Header="خصم مبلغ" Binding="{Binding DiscountAmount}" Width="*"/>
                        <DataGridTextColumn Header="ضريبة %" Binding="{Binding TaxPercentage}" Width="*"/>
                        <DataGridTextColumn Header="ضريبة مبلغ" Binding="{Binding TaxAmount}" Width="*"/>
                        <DataGridTextColumn Header="الإجمالي النهائي" Binding="{Binding LineTotal,Mode=OneWay}" Width="1.5*"/>

                        <DataGridTemplateColumn Width="50"
                                                Visibility="{Binding DataContext.IsEditable, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="🗑" Background="Transparent" BorderThickness="0" Foreground="Red" FontSize="{StaticResource FontSizeNormal}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Totals -->
        <Border Grid.Row="3" Margin="0,20,0,0" Padding="15" Background="#f8f9fa" CornerRadius="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <StackPanel Margin="20,0">
                    <TextBlock Text="الإجمالي قبل الخصم" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N2}}" FontSize="{StaticResource FontSizeMedium}" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Margin="20,0">
                    <TextBlock Text="إجمالي الخصم" FontSize="{StaticResource FontSizeSmall}" Foreground="#e74c3c"/>
                    <TextBlock Text="{Binding TotalDiscount, StringFormat={}{0:N2}}" FontSize="{StaticResource FontSizeMedium}" FontWeight="Bold" Foreground="#e74c3c"/>
                </StackPanel>
                <StackPanel Margin="20,0">
                    <TextBlock Text="إجمالي الضريبة" FontSize="{StaticResource FontSizeSmall}" Foreground="#2980b9"/>
                    <TextBlock Text="{Binding TotalTax, StringFormat={}{0:N2}}" FontSize="{StaticResource FontSizeMedium}" FontWeight="Bold" Foreground="#2980b9"/>
                </StackPanel>
                <StackPanel Margin="20,0">
                    <TextBlock Text="الصافي النهائي" FontSize="{StaticResource FontSizeSmall}" Foreground="#7f8c8d"/>
                    <TextBlock Text="{Binding FinalAmount, StringFormat={}{0:N2}}" FontSize="{StaticResource FontSizeLarge}" FontWeight="Bold" Foreground="{StaticResource PrimaryHeaderBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
