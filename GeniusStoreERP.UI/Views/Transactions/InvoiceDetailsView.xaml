<UserControl x:Class="GeniusStoreERP.UI.Views.Transactions.InvoiceDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GeniusStoreERP.UI.Views.Transactions"
             xmlns:vmt="clr-namespace:GeniusStoreERP.UI.ViewModels.Transactions"
             mc:Ignorable="d" 
             FlowDirection="RightToLeft"
             d:DesignHeight="850" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vmt:InvoiceDetailsViewModel}">

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Action Bar -->
        <Border Grid.Row="0" Background="White" Padding="25,15" Effect="{StaticResource UnifiedCardStyle_ShadowOnly}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding BackCommand}" Style="{StaticResource UnifiedPrimaryButtonStyle}" Width="40" Height="40" Background="#F1F3F5" Margin="0,0,15,0">
                        <Viewbox Width="20" Height="20">
                            <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Fill="#495057" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform ScaleX="-1"/>
                                </Path.RenderTransform>
                            </Path>
                        </Viewbox>
                    </Button>
                    <TextBlock Text="تفاصيل الفاتورة" Style="{StaticResource MainHeaderStyle}" VerticalAlignment="Center" Margin="0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Void Button -->
                    <Button Command="{Binding VoidCommand}" Content="إلغاء الفاتورة" Style="{StaticResource UnifiedPrimaryButtonStyle}" Background="#EF5350" Width="130" Margin="0,0,12,0" Visibility="{Binding CanVoid, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    
                    <!-- Export Actions -->
                    <Border BorderBrush="#DEE2E6" BorderThickness="1,0,0,0" Margin="0,5,12,5" Padding="12,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding ExportPdfCommand}" Content="تصدير PDF" Style="{StaticResource UnifiedPrimaryButtonStyle}" Background="#2A5298" Width="110" Margin="0,0,8,0"/>
                            <Button Command="{Binding ExportExcelCommand}" Content="تصدير Excel" Style="{StaticResource UnifiedPrimaryButtonStyle}" Background="#1D6F42" Width="110" Margin="0,0,8,0"/>
                            <Button Command="{Binding ExportWordCommand}" Content="تصدير Word" Style="{StaticResource UnifiedPrimaryButtonStyle}" Background="#2B579A" Width="110"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Invoice Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="40">
            <Border Style="{StaticResource UnifiedCardStyle}" MaxWidth="900" HorizontalAlignment="Center">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header Info -->
                        <RowDefinition Height="Auto"/> <!-- Partner Info -->
                        <RowDefinition Height="*"/>    <!-- Item Table -->
                        <RowDefinition Height="Auto"/> <!-- Totals -->
                    </Grid.RowDefinitions>

                    <!-- Row 0: Invoice Metadata & Branding Placeholder -->
                    <Grid Grid.Row="0" Margin="0,0,0,40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Invoice.InvoiceNumber}" FontSize="28" FontWeight="ExtraBold" Foreground="{StaticResource PrimaryHeaderBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="#EEF2FF" CornerRadius="4" Padding="8,4" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding Invoice.InvoiceDate, StringFormat=dd/MM/yyyy}" FontSize="13" Foreground="{StaticResource AccentActionBrush}" FontWeight="SemiBold"/>
                                </Border>
                                <Border x:Name="StatusBadge" CornerRadius="4" Padding="8,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Invoice.InvoiceStatusId}" Value="2">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Invoice.StatusName}" FontSize="13" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Invoice.InvoiceStatusId}" Value="2">
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Branding / General Info Side -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <TextBlock Text="اسم النظام" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryHeaderBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Genius Store ERP" FontSize="12" Foreground="#7F8C8D" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 1: Partner (Customer/Supplier) Box -->
                    <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="12" Padding="25" Margin="0,0,0,40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,40,0">
                                <TextBlock Text="فاتورة إلى:" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding Invoice.PartnerName}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource MainContentTextBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="ملاحظات:" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding Invoice.Notes}" FontSize="14" Foreground="{StaticResource MainContentTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Row 2: Items Table -->
                    <Border Grid.Row="2" BorderBrush="#EEEEEE" BorderThickness="0,1,0,1" Padding="0,20">
                        <DataGrid ItemsSource="{Binding Invoice.InvoiceItems}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="None" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="2*"/>
                                <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="0.8*"/>
                                <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPrice, StringFormat={}{0:N2}}" Width="*"/>
                                <DataGridTextColumn Header="إجمالي السعر" Binding="{Binding LineTotal, StringFormat={}{0:N2}}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="الضريبة" Binding="{Binding TaxAmount, StringFormat={}{0:N2}}" Width="0.8*"/>
                                <DataGridTextColumn Header="الخصم" Binding="{Binding DisCountAmount, StringFormat={}{0:N2}}" Width="0.8*"/>
                                <DataGridTextColumn Header="الصافي" Binding="{Binding NetLineTotal, StringFormat={}{0:N2}}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentActionBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Row 3: Totals Summary -->
                    <StackPanel Grid.Row="3" HorizontalAlignment="Left" Width="350" Margin="0,30,0,0">
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="الإجمالي (قبل الضريبة والخصم)" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Invoice.TotalItemsAmount, StringFormat={}{0:N2}}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="إجمالي الضريبة (+)" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Invoice.TotalItemsTax, StringFormat={}{0:N2}}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#2E7D32"/>
                        </Grid>
                        
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="إجمالي الخصم (-)" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Invoice.TotalItemsDiscount, StringFormat={}{0:N2}}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#C62828"/>
                        </Grid>
                        
                        <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Margin="0,15,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="صافي الفاتورة النهائي" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryHeaderBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Invoice.FinalAmount, StringFormat={}{0:N2}}" FontSize="22" FontWeight="ExtraBold" Foreground="{StaticResource AccentActionBrush}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
