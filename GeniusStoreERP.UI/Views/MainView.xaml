<?xml version="1.0" encoding="UTF-8"?>
<Window
  x:Class="GeniusStoreERP.UI.Views.MainView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:GeniusStoreERP.UI.Views"
  xmlns:vm="clr-namespace:GeniusStoreERP.UI.ViewModels"
  mc:Ignorable="d"
  Title="Genius Store ERP"
  WindowState="Maximized"
  MinHeight="600"
  MinWidth="1000"
  WindowStartupLocation="CenterScreen"
  FlowDirection="RightToLeft"
  Background="{StaticResource MainBackgroundBrush}"
  Icon="pack://application:,,,/GeniusStoreERP.UI;component/Resources/app_icon.png"
  FontFamily="{StaticResource MainFontFamily}">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/GeniusStoreERP.UI;component/Resources/DataTemplates.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="200"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <!-- ═══════════════════════════════════════════ -->
    <!-- SIDEBAR -->
    <!-- ═══════════════════════════════════════════ -->
    <Border Grid.Column="0"
        Background="{StaticResource SidebarBackgroundBrush}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Logo Area -->
        <Border Grid.Row="0"
            Padding="20,25,20,20">
          <StackPanel Orientation="Horizontal"
              VerticalAlignment="Center">
            <Border
              Width="32"
              Height="32"
              CornerRadius="8">
              <Image Source="pack://application:,,,/GeniusStoreERP.UI;component/Resources/app_icon.png"
                     RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
            <StackPanel Margin="10,0,0,0"
                VerticalAlignment="Center">
              <TextBlock
                Text="Genius Store"
                Foreground="White"
                FontFamily="{StaticResource MainFontFamily}"
                FontSize="17"
                FontWeight="Bold"/>
              <TextBlock
                Text="ERP System"
                Foreground="#7986CB"
                FontFamily="{StaticResource MainFontFamily}"
                FontSize="12"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <!-- Separator -->
        <Border
          Grid.Row="0"
          Height="1"
          Background="#263594"
          VerticalAlignment="Bottom"
          Margin="15,0"/>
        <!-- Navigation Items -->
        <ListBox
          Grid.Row="1"
          ItemsSource="{Binding NavItems}"
          ItemContainerStyle="{StaticResource SidebarNavItemStyle}"
          Background="Transparent"
          BorderThickness="0"
          Margin="0,15,0,0"/>
        <!-- User Profile Section -->
        <Border Grid.Row="2"
            Background="#13196B"
            Padding="15,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Avatar -->
            <Border
              Width="36"
              Height="36"
              Background="{StaticResource AccentActionBrush}"
              CornerRadius="8">
              <TextBlock
                Text="{Binding FullName[0]}"
                Foreground="White"
                FontWeight="Bold"
                FontFamily="{StaticResource MainFontFamily}"
                FontSize="{StaticResource FontSizeNormal}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
            </Border>
            <!-- User Info -->
            <StackPanel Grid.Column="1"
                Margin="10,0"
                VerticalAlignment="Center">
              <TextBlock
                Text="{Binding FullName}"
                Foreground="White"
                FontFamily="{StaticResource MainFontFamily}"
                FontSize="{StaticResource FontSizeSmall}"
                FontWeight="SemiBold"
                TextTrimming="CharacterEllipsis"/>
              <TextBlock
                Text="{Binding UserRole}"
                Foreground="#7986CB"
                FontFamily="{StaticResource MainFontFamily}"
                FontSize="12"/>
            </StackPanel>
            <!-- Logout Button -->
            <Button
              Grid.Column="2"
              Command="{Binding LogoutCommand}"
              Background="Transparent"
              BorderThickness="0"
              Cursor="Hand"
              ToolTip="تسجيل الخروج"
              Width="32"
              Height="32">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border
                    x:Name="LogoutBorder"
                    Background="Transparent"
                    CornerRadius="8"
                    Padding="5">
                    <Viewbox Width="16"
                        Height="16">
                      <Path
                        x:Name="LogoutIcon"
                        Data="M10,17V14H3V10H10V7L15,12L10,17M7,2H17A2,2 0 0,1 19,4V20A2,2 0 0,1 17,22H7A2,2 0 0,1 5,20V18H7V20H17V4H7V6H5V4A2,2 0 0,1 7,2Z"
                        Fill="#EF5350"
                        Stretch="Uniform"/>
                    </Viewbox>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver"
                        Value="True">
                      <Setter TargetName="LogoutBorder"
                          Property="Background"
                          Value="#1F285E"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </Grid>
        </Border>
      </Grid>
    </Border>
    <!-- ═══════════════════════════════════════════ -->
    <!-- MAIN CONTENT -->
    <!-- ═══════════════════════════════════════════ -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="65"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <!-- Top Header Bar -->
      <Border
        Grid.Row="0"
        Background="White"
        Padding="25,0"
        Effect="{StaticResource UnifiedCardStyle_ShadowOnly}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <!-- Section Title -->
          <TextBlock
            Grid.Column="0"
            Text="{Binding SelectedNavItem.Title}"
            FontFamily="{StaticResource MainFontFamily}"
            FontSize="22"
            FontWeight="Bold"
            Foreground="{StaticResource MainContentTextBrush}"
            VerticalAlignment="Center"/>
          <!-- User Session Info -->
          <Border Grid.Column="1"
              Background="#EEF2FF"
              CornerRadius="10"
              Padding="10,6"
              VerticalAlignment="Center">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <!-- Avatar -->
              <Border
                Width="34"
                Height="34"
                Background="{StaticResource AccentActionBrush}"
                CornerRadius="8"
                VerticalAlignment="Center">
                <TextBlock
                  Text="{Binding FullName[0]}"
                  Foreground="White"
                  FontWeight="Bold"
                  FontFamily="{StaticResource MainFontFamily}"
                  FontSize="{StaticResource FontSizeSmall}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"/>
              </Border>

              <!-- User Info -->
              <StackPanel Grid.Column="1"
                  Margin="10,0"
                  VerticalAlignment="Center">
                <TextBlock
                  Text="{Binding FullName}"
                  Foreground="{StaticResource MainContentTextBrush}"
                  FontFamily="{StaticResource MainFontFamily}"
                  FontSize="13"
                  FontWeight="SemiBold"
                  TextTrimming="CharacterEllipsis"/>
                <TextBlock
                  Text="{Binding UserRole}"
                  Foreground="#607D8B"
                  FontFamily="{StaticResource MainFontFamily}"
                  FontSize="11"/>
              </StackPanel>

              <!-- Logout Button -->
              <Button
                Grid.Column="2"
                Command="{Binding LogoutCommand}"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                ToolTip="تسجيل الخروج"
                Width="32"
                Height="32"
                VerticalAlignment="Center">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <Border
                      x:Name="HeaderLogoutBorder"
                      Background="Transparent"
                      CornerRadius="8"
                      Padding="5">
                      <Viewbox Width="16"
                          Height="16">
                        <Path
                          Data="M10,17V14H3V10H10V7L15,12L10,17M7,2H17A2,2 0 0,1 19,4V20A2,2 0 0,1 17,22H7A2,2 0 0,1 5,20V18H7V20H17V4H7V6H5V4A2,2 0 0,1 7,2Z"
                          Fill="#EF5350"
                          Stretch="Uniform"/>
                      </Viewbox>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver"
                          Value="True">
                        <Setter TargetName="HeaderLogoutBorder"
                            Property="Background"
                            Value="#DDE4FF"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Button.Template>
              </Button>
            </Grid>
          </Border>
        </Grid>
      </Border>
      <!-- Dynamic Content -->
      <ContentControl Grid.Row="1"
          Content="{Binding CurrentViewModel}"
          Margin="0"/>
    </Grid>
  </Grid>
</Window>
