<Window x:Class="GeniusStoreERP.UI.Views.ReportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:GeniusStoreERP.UI.ViewModels"
        mc:Ignorable="d"
        Title="{Binding ReportTitle}" 
        Height="850" Width="1100"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="{StaticResource MainBackgroundBrush}"
        FontFamily="{StaticResource MainFontFamily}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Modern Toolbar -->
        <Border Grid.Row="0" Background="White" Padding="20,12" Effect="{StaticResource UnifiedCardStyle_ShadowOnly}">
            <DockPanel>
                <!-- Right Actions: Export & Print -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding ExportToExcelCommand}"
                            Style="{StaticResource UnifiedPrimaryButtonStyle}"
                            Background="#F1F3F5" Foreground="{StaticResource MainContentTextBrush}"
                            Width="130" Margin="10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="تصدير Excel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SavePdfCommand}"
                            Style="{StaticResource UnifiedPrimaryButtonStyle}"
                            Background="#E3F2FD" Foreground="{StaticResource AccentActionBrush}"
                            Width="130" Margin="10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="حفظ كـ PDF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding PrintCommand}" 
                            Style="{StaticResource UnifiedPrimaryButtonStyle}"
                            Width="130" Margin="10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="طباعة الآن" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Left Actions: Zoom & Close -->
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource UnifiedPrimaryButtonStyle}"
                            Background="#FFF1F0" Foreground="#F5222D"
                            Content="إغلاق المعاينة" Width="120" Margin="0,0,20,0"/>

                    <Border Width="1" Background="#E0E0E0" Margin="10,5"/>

                    <!-- Zoom Controls -->
                    <StackPanel Orientation="Horizontal" Margin="10,0">
                        <Button Command="{Binding ZoomOutCommand}" 
                                Style="{StaticResource UnifiedPrimaryButtonStyle}"
                                Background="#F5F5F5" Foreground="#595959"
                                Content="-" Width="35" Height="35" FontSize="18"/>
                        
                        <Border Background="#F9F9F9" CornerRadius="4" Margin="8,0" Padding="12,0" MinWidth="60">
                            <TextBlock Text="{Binding ZoomLevel, StringFormat={}{0}%}" 
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MainContentTextBrush}"/>
                        </Border>

                        <Button Command="{Binding ZoomInCommand}" 
                                Style="{StaticResource UnifiedPrimaryButtonStyle}"
                                Background="#F5F5F5" Foreground="#595959"
                                Content="+" Width="35" Height="35" FontSize="18"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Report Viewer Content -->
        <Border Grid.Row="1" Margin="20" Background="White" CornerRadius="12" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>
            <wv2:WebView2 x:Name="PdfViewer" />
        </Border>

        <!-- Professional Status Bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="25,10">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource StatusSuccessBrush}" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding StatusText}" 
                               Foreground="#595959" 
                               FontSize="12" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding PageInfo}" 
                               Foreground="#8C8C8C" 
                               FontSize="12" 
                               FontWeight="Medium"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
