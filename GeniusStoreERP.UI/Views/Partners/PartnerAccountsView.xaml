<UserControl x:Class="GeniusStoreERP.UI.Views.Partners.PartnerAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GeniusStoreERP.UI.Views.Partners"
             xmlns:vm="clr-namespace:GeniusStoreERP.UI.ViewModels.Partners"
             mc:Ignorable="d" 
             FlowDirection="RightToLeft"
             d:DesignHeight="700" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:PartnerAccountsViewModel}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="حسابات الشركاء" Style="{StaticResource MainHeaderStyle}" FontSize="28"/>
                <TextBlock Text="عرض موازين أرصدة العملاء والموردين" Style="{StaticResource SubHeaderStyle}" FontSize="16"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search Box -->
                <Border Style="{StaticResource UnifiedInputContainerStyle}" Width="250" Margin="0,0,15,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Viewbox Width="16" Height="16" HorizontalAlignment="Center">
                            <Path Data="M15.5,14L11.8,10.3C12.5,9.2 13,7.9 13,6.5C13,2.9 10.1,0 6.5,0C2.9,0 0,2.9 0,6.5C0,10.1 2.9,13 6.5,13C7.9,13 9.2,12.5 10.3,11.8L14,15.5L15.5,14M6.5,11C4,11 2,9 2,6.5C2,4 4,2 6.5,2C9,2 11,4 11,6.5C11,9 9,11 6.5,11Z" Fill="#7F8C8D"/>
                        </Viewbox>
                        <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Tag="بحث بالاسم أو الهاتف..." Style="{StaticResource UnifiedTextBoxStyle}"/>
                    </Grid>
                </Border>

                <!-- Filters -->
                <CheckBox Content="عملاء" IsChecked="{Binding IsCustomerFilter}" Margin="0,0,15,0" Style="{StaticResource UnifiedCheckBoxStyle}"/>
                <CheckBox Content="موردين" IsChecked="{Binding IsSupplierFilter}" Margin="0,0,15,0" Style="{StaticResource UnifiedCheckBoxStyle}"/>
                
                <Button Command="{Binding RefreshCommand}" Style="{StaticResource UnifiedSecondaryButtonStyle}" Width="40" Margin="10,0,0,0">
                    <Viewbox Width="16" Height="16">
                        <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Fill="{StaticResource AccentActionBrush}"/>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Data Grid Section -->
        <Border Grid.Row="1" Style="{StaticResource UnifiedCardStyle}" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Accounts}" AutoGenerateColumns="False" 
                          HeadersVisibility="Column" SelectionMode="Single"
                          GridLinesVisibility="None" BorderThickness="0" Background="Transparent">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الكود" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="رقم الهاتف" Binding="{Binding PhoneNumber}" Width="150"/>
                        
                        <DataGridTemplateColumn Header="النوع" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Visibility="{Binding IsCustomer, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                                Background="#E8F5E9" CornerRadius="10" Padding="8,2" Margin="0,0,4,0">
                                            <TextBlock Text="عميل" FontSize="13" Foreground="#2E7D32" FontWeight="Bold"/>
                                        </Border>
                                        <Border Visibility="{Binding IsSupplier, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                                Background="#E3F2FD" CornerRadius="10" Padding="8,2">
                                             <TextBlock Text="مورد" FontSize="13" Foreground="#1565C0" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="إجمالي مدين" Binding="{Binding TotalDebit, StringFormat=N2}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="إجمالي دائن" Binding="{Binding TotalCredit, StringFormat=N2}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                         <DataGridTemplateColumn Header="الرصيد الحالي" Width="150">
                             <DataGridTemplateColumn.CellTemplate>
                                 <DataTemplate>
                                     <TextBlock Text="{Binding Balance, StringFormat=N2}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                                         <TextBlock.Style>
                                             <Style TargetType="TextBlock">
                                                 <Setter Property="Foreground" Value="{StaticResource MainContentTextBrush}"/>
                                                 <Style.Triggers>
                                                     <DataTrigger Binding="{Binding Balance, Converter={StaticResource ResourceKeyToBrushConverter}}" Value="Leh">
                                                         <Setter Property="Foreground" Value="#2E7D32"/>
                                                     </DataTrigger>
                                                     <DataTrigger Binding="{Binding Balance, Converter={StaticResource ResourceKeyToBrushConverter}}" Value="Alaih">
                                                         <Setter Property="Foreground" Value="#C62828"/>
                                                     </DataTrigger>
                                                 </Style.Triggers>
                                             </Style>
                                         </TextBlock.Style>
                                     </TextBlock>
                                 </DataTemplate>
                             </DataGridTemplateColumn.CellTemplate>
                         </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="الإجراءات" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                 <DataTemplate>
                                     <Button Command="{Binding DataContext.ViewStatementCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                             CommandParameter="{Binding}"
                                             Content="كشف حساب" Style="{StaticResource UnifiedSecondaryButtonStyle}" 
                                             FontSize="13" Height="28" Padding="10,0"/>
                                 </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading Overlay -->
                <Border Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                         <TextBlock Text="جاري التحميل..." FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentActionBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Pagination -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Command="{Binding PreviousPageCommand}" Content="السابق" Style="{StaticResource UnifiedSecondaryButtonStyle}" Width="80" Margin="0,0,10,0"/>
             <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold">
                 <Run Text="صفحة "/>
                 <Run Text="{Binding CurrentPage}"/>
                 <Run Text=" من "/>
                 <Run Text="{Binding TotalPages, Mode=OneWay}"/>
             </TextBlock>
            <Button Command="{Binding NextPageCommand}" Content="التالي" Style="{StaticResource UnifiedSecondaryButtonStyle}" Width="80" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
