<UserControl x:Class="GeniusStoreERP.UI.Views.Partners.PartnerStatementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GeniusStoreERP.UI.Views.Partners"
             xmlns:vm="clr-namespace:GeniusStoreERP.UI.ViewModels.Partners"
             mc:Ignorable="d" 
             FlowDirection="RightToLeft"
             d:DesignHeight="800" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:PartnerStatementViewModel}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Actions -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Button Command="{Binding GoBackCommand}" HorizontalAlignment="Left" Style="{StaticResource UnifiedSecondaryButtonStyle}" Width="120">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                        <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Fill="{StaticResource AccentActionBrush}"/>
                    </Viewbox>
                    <TextBlock Text="عودة للخلف" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding PrintCommand}" Style="{StaticResource UnifiedPrimaryButtonStyle}" Width="140" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                            <Path Data="M18,3H6V7H18M19,12A1,1 0 0,1 18,11A1,1 0 0,1 19,10A1,1 0 0,1 20,11A1,1 0 0,1 19,12M16,19H8V14H16M19,8H5A3,3 0 0,0 2,11V17H6V21H18V17H22V11A3,3 0 0,0 19,8Z" Fill="White"/>
                        </Viewbox>
                        <TextBlock Text="طباعة الكشف" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Partner Info & Filters -->
        <Border Grid.Row="1" Style="{StaticResource UnifiedCardStyle}" Margin="0,0,0,20" Background="{StaticResource SidebarBackgroundBrush}">
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Statement.Partner.Name}" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="هاتف: " Foreground="White" Opacity="0.7"/>
                        <TextBlock Text="{Binding Statement.Partner.PhoneNumber}" Foreground="White" Margin="0,0,20,0"/>
                        <TextBlock Text="الرصيد النهائي: " Foreground="White" Opacity="0.7"/>
                        <TextBlock Text="{Binding Statement.ClosingBalance, StringFormat=N2}" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="من:" VerticalAlignment="Center" Foreground="White" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding FromDate, UpdateSourceTrigger=PropertyChanged}" Width="130" Margin="0,0,15,0"/>
                    
                    <TextBlock Text="إلى:" VerticalAlignment="Center" Foreground="White" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding ToDate, UpdateSourceTrigger=PropertyChanged}" Width="130" Margin="0,0,15,0"/>
                    
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource UnifiedSecondaryButtonStyle}" Width="40">
                        <Viewbox Width="16" Height="16">
                            <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Fill="White"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Statement Table -->
        <Border Grid.Row="2" Style="{StaticResource UnifiedCardStyle}" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Statement.Items}" AutoGenerateColumns="False" 
                          HeadersVisibility="Column" SelectionMode="Single"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F3F5"
                          BorderThickness="0" Background="Transparent" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding Date, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                        <DataGridTextColumn Header="نوع العملية" Binding="{Binding TransactionType}" Width="150"/>
                        <DataGridTextColumn Header="رقم المرجع" Binding="{Binding ReferenceNumber}" Width="120"/>
                        <DataGridTextColumn Header="البيان/الملاحظات" Binding="{Binding Remarks}" Width="*"/>
                        <DataGridTextColumn Header="مدين (+)" Binding="{Binding Debit, StringFormat=N2}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#C62828"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="دائن (-)" Binding="{Binding Credit, StringFormat=N2}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="الرصيد المتراكم" Binding="{Binding RunningBalance, StringFormat=N2}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading Overlay -->
                <Border Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="جاري جلب القيود..." FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentActionBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Footer Summary -->
        <Border Grid.Row="3" Background="#F8F9FA" CornerRadius="0,0,12,12" Padding="20,15" BorderThickness="1,0,1,1" BorderBrush="#E9ECEF">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="الرصيد المقيد قبل هذه الفترة (رصيد افتتاحي): " Foreground="#7F8C8D"/>
                    <TextBlock Text="{Binding Statement.OpeningBalance, StringFormat=N2}" FontWeight="Bold" Margin="5,0,0,0"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="صافي الرصيد الختامي: " FontSize="16" VerticalAlignment="Center" Foreground="{StaticResource MainContentTextBrush}"/>
                    <TextBlock Text="{Binding Statement.ClosingBalance, StringFormat=N2}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentActionBrush}" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
