<UserControl x:Class="GeniusStoreERP.UI.Views.Partners.PartnerEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             FlowDirection="RightToLeft">

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="{Binding Title}"
                   Style="{StaticResource MainHeaderStyle}"
                   Margin="30,20,30,20"
                   Grid.Row="0"/>

        <!-- Content Grid with 2 Columns -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="30,0,30,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <!-- Name Field -->
                    <RowDefinition Height="Auto"/>
                    <!-- Phone Field -->
                    <RowDefinition Height="Auto"/>
                    <!-- Email Field -->
                    <RowDefinition Height="Auto"/>
                    <!-- Address Field -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name Field -->
                <TextBlock Text="اسم الشريك"
                           Style="{StaticResource FieldLabelStyle}"
                           Grid.Row="0"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,15,10,15"/>
                <Border Style="{StaticResource UnifiedInputContainerStyle}"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="0,10,0,10">
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource UnifiedTextBoxStyle}"/>
                </Border>

                <!-- Phone Field -->
                <TextBlock Text="رقم الهاتف"
                           Style="{StaticResource FieldLabelStyle}"
                           Grid.Row="1"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,15,10,15"/>
                <Border Style="{StaticResource UnifiedInputContainerStyle}"
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="0,10,0,10">
                    <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource UnifiedTextBoxStyle}"/>
                </Border>

                <!-- Email Field -->
                <TextBlock Text="البريد الإلكتروني"
                           Style="{StaticResource FieldLabelStyle}"
                           Grid.Row="2"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,15,10,15"/>
                <Border Style="{StaticResource UnifiedInputContainerStyle}"
                        Grid.Row="2"
                        Grid.Column="1"
                        Margin="0,10,0,10">
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource UnifiedTextBoxStyle}"/>
                </Border>

                <!-- Address Field -->
                <TextBlock Text="العنوان"
                           Style="{StaticResource FieldLabelStyle}"
                           Grid.Row="3"
                           Grid.Column="0"
                           VerticalAlignment="Top"
                           Margin="0,15,10,15"/>
                <Border Style="{StaticResource UnifiedInputContainerStyle}"
                        Grid.Row="3"
                        Grid.Column="1"
                        Height="120"
                        Margin="0,10,0,10">
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource UnifiedTextBoxStyle}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"/>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Grid Grid.Row="2"
              Margin="30,20,30,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Command="{Binding SaveCommand}"
                    Content="حفظ البيانات"
                    Style="{StaticResource UnifiedPrimaryButtonStyle}"
                    Grid.Column="0"
                    Margin="0,0,10,0"/>

            <Button Command="{Binding CancelCommand}"
                    Content="إلغاء"
                    Background="#F5F6F7"
                    Foreground="#7F8C8D"
                    Style="{StaticResource UnifiedPrimaryButtonStyle}"
                    Grid.Column="1"
                    Margin="10,0,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</UserControl>
