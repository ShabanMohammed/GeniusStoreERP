<UserControl x:Class="GeniusStoreERP.UI.Views.CategoryListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:GeniusStoreERP.UI.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style x:Key="CategoryDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="ColumnHeaderHeight" Value="45"/>
            <Setter Property="RowHeight" Value="50"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="{StaticResource MainFontFamily}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F3F5"/>
            <Setter Property="Foreground" Value="{StaticResource MainContentTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F1F3F5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E9ECEF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionHighlightBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource MainContentTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header & Search -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Pagination -->
        </Grid.RowDefinitions>

        <!-- Top Section: Header & Actions -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="إدارة التصنيفات" Style="{StaticResource MainHeaderStyle}" Grid.Column="0" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <!-- Search Bar -->
                <Border Style="{StaticResource UnifiedInputContainerStyle}" Width="300" Margin="0,0,15,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Viewbox Width="18" Height="18" Margin="10,0,0,0">
                            <Path Data="{StaticResource IconSearch}" 
                                  Fill="#95A5A6" Stretch="Uniform"/>
                        </Viewbox>
                        <TextBox Grid.Column="1" 
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource UnifiedTextBoxStyle}"
                                 Tag="بحث عن تصنيف..."/>
                    </Grid>
                </Border>

                <!-- Add Button -->
                <Button Command="{Binding AddCommand}" Style="{StaticResource UnifiedPrimaryButtonStyle}" Width="150" ToolTip="إضافة تصنيف جديد">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                            <Path Data="{StaticResource IconAdd}" Fill="White" Stretch="Uniform"/>
                        </Viewbox>
                        <TextBlock Text="إضافة تصنيف" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Center Section: DataGrid Area -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Effect="{StaticResource UnifiedCardStyle_ShadowOnly}">
            <DataGrid ItemsSource="{Binding Categories}" 
                      SelectedItem="{Binding SelectedCategory}"
                      Style="{StaticResource CategoryDataGridStyle}">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding EditCommand}" 
                                  CommandParameter="{Binding SelectedCategory}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="كود" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="اسم التصنيف" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="الوصف" Binding="{Binding Description}" Width="2*"/>

                    <!-- Actions Column -->
                    <DataGridTemplateColumn Header="الإجراءات" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- Edit Button -->
                                    <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding }"
                                            Background="Transparent" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand" ToolTip="تعديل">
                                        <Viewbox Width="18" Height="18">
                                            <Path Data="{StaticResource IconEdit}" 
                                                  Fill="{StaticResource AccentActionBrush}" Stretch="Uniform"/>
                                        </Viewbox>
                                    </Button>

                                    <!-- Delete Button -->
                                    <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="حذف">
                                        <Viewbox Width="18" Height="18">
                                            <Path Data="{StaticResource IconDelete}" 
                                                  Fill="#E74C3C" Stretch="Uniform"/>
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Bottom Section: Pagination -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Page Size Selector -->
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock Text="عرض" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13" Foreground="#7F8C8D"/>
                <Border Style="{StaticResource UnifiedInputContainerStyle}" Height="35" Margin="0" Padding="2">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding DecreasePageSizeCommand}" 
                                Content="-" 
                                Width="25" 
                                Background="Transparent" 
                                BorderThickness="0"
                                FontWeight="Bold"
                                Cursor="Hand"/>
                        <TextBox Text="{Binding PageSize}" 
                                 IsReadOnly="True"
                                 Width="30"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Padding="0"/>
                        <Button Command="{Binding IncreasePageSizeCommand}" 
                                Content="+" 
                                Width="25" 
                                Background="Transparent" 
                                BorderThickness="0"
                                FontWeight="Bold"
                                Cursor="Hand"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="عناصر لكل صفحة" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="13" Foreground="#7F8C8D"/>
            </StackPanel>

            <!-- Summary Text -->
            <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="#7F8C8D">
                <Run Text="عرض القيمة "/>
                <Run Text="{Binding Categories.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                <Run Text=" من إجمالي "/>
                <Run Text="{Binding TotalItems}" FontWeight="SemiBold"/>
                <Run Text=" عنصر"/>
            </TextBlock>

            <!-- Navigation Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <!-- First Page -->
                <Button Command="{Binding FirstPageCommand}" 
                        Style="{StaticResource UnifiedPrimaryButtonStyle}" 
                        Width="40" Height="35" Padding="0" Margin="0,0,5,0"
                        ToolTip="الصفحة الأولى">
                    <TextBlock Text="|«" FontWeight="Bold" FontSize="16"/>
                </Button>

                <!-- Previous Page -->
                <Button Command="{Binding PreviousPageCommand}" 
                        Style="{StaticResource UnifiedPrimaryButtonStyle}" 
                        Width="40" Height="35" Padding="0"
                        ToolTip="الصفحة السابقة">
                    <TextBlock Text="«" FontWeight="Bold" FontSize="16"/>
                </Button>

                <!-- Page Info -->
                <Border Background="#F1F3F5" CornerRadius="5" Padding="15,0" Margin="5,0">
                    <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold">
                        <Run Text="صفحة"/>
                        <Run Text=" "/>
                        <Run Text="{Binding CurrentPage}"/>
                        <Run Text=" "/>
                        <Run Text="من"/>
                        <Run Text=" "/>
                        <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                    </TextBlock>
                </Border>

                <!-- Next Page -->
                <Button Command="{Binding NextPageCommand}" 
                        Style="{StaticResource UnifiedPrimaryButtonStyle}" 
                        Width="40" Height="35" Padding="0"
                        ToolTip="الصفحة التالية">
                    <TextBlock Text="»" FontWeight="Bold" FontSize="16"/>
                </Button>

                <!-- Last Page -->
                <Button Command="{Binding LastPageCommand}" 
                        Style="{StaticResource UnifiedPrimaryButtonStyle}" 
                        Width="40" Height="35" Padding="0" Margin="5,0,0,0"
                        ToolTip="الصفحة الأخيرة">
                    <TextBlock Text="»|" FontWeight="Bold" FontSize="16"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
