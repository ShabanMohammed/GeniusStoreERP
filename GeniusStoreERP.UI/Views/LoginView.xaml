<Window x:Class="GeniusStoreERP.UI.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GeniusStoreERP.UI.Views"
        mc:Ignorable="d"
        Title="تسجيل الدخول - Genius Store ERP" 
        Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource MainFontFamily}"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border Background="{StaticResource MainBackgroundBrush}" CornerRadius="20">
        <Grid>
            <!-- Close Button -->
            <Button Content="✕" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top"
                    Margin="15"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{StaticResource MainContentTextBrush}"
                    FontSize="22"
                    Cursor="Hand"
                    IsCancel="True"
                    Click="Close_Click"/>

            <StackPanel VerticalAlignment="Center" Margin="30,0">
                
                <!-- Logo/Header Area -->
                <Border Width="60" Height="60" 
                        Background="{StaticResource PrimaryHeaderBrush}" 
                        CornerRadius="15"
                        Margin="0,0,0,20">
                    <TextBlock Text="G" 
                               Foreground="White" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>
                
                <TextBlock Text="مرحباً بك مجدداً" 
                           Style="{StaticResource MainHeaderStyle}"
                           HorizontalAlignment="Center"/>
                
                <TextBlock Text="قم بتسجيل الدخول للمتابعة إلى النظام" 
                           Style="{StaticResource SubHeaderStyle}"
                           HorizontalAlignment="Center"/>

                <!-- Unified Card -->
                <Border Style="{StaticResource UnifiedCardStyle}">
                    <StackPanel>
                        <!-- Username Field -->
                        <TextBlock Text="اسم المستخدم" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource UnifiedInputContainerStyle}">
                            <TextBox Style="{StaticResource UnifiedTextBoxStyle}"
                                     Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>

                        <!-- Password Field -->
                        <TextBlock Text="كلمة المرور" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource UnifiedInputContainerStyle}">
                            <PasswordBox x:Name="PasswordInput"
                                         Style="{StaticResource UnifiedPasswordBoxStyle}"
                                         PasswordChanged="PasswordInput_PasswordChanged"/>
                        </Border>

                        <!-- Actions -->
                        <Button Content="دخول إلى النظام" 
                                Style="{StaticResource UnifiedPrimaryButtonStyle}"
                                Command="{Binding LoginCommand}"
                                IsDefault="True"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
                
                <TextBlock Text="© 2024 Genius Store ERP - جميع الحقوق محفوظة" 
                           Margin="0,30,0,0"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Foreground="#BDC3C7"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>