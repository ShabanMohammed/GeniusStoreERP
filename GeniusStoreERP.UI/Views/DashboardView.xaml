<UserControl x:Class="GeniusStoreERP.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:common="clr-namespace:GeniusStoreERP.UI.Common"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style x:Key="TaskCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="20" 
                                BorderBrush="#F0F3F5" 
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Direction="-45" Opacity="0.08" ShadowDepth="4"/>
                            </Border.Effect>
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Border x:Name="iconBg" Width="60" Height="60" Background="#F8F9FA" CornerRadius="12" HorizontalAlignment="Center">
                                    <Viewbox Width="32" Height="32">
                                        <Path x:Name="path" 
                                              Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ResourceKeyToDataConverter}}" 
                                              Fill="{StaticResource AccentActionBrush}" 
                                              Stretch="Uniform"/>
                                    </Viewbox>
                                </Border>
                                
                                <TextBlock Grid.Row="1" 
                                           Text="{TemplateBinding Content}" 
                                           FontSize="{StaticResource FontSizeMedium}" 
                                           FontWeight="Bold" 
                                           Foreground="#2C3E50" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,15,0,0"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F0F4FF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentActionBrush}"/>
                                <Setter TargetName="iconBg" Property="Background" Value="White"/>
                                <Setter TargetName="path" Property="Fill" Value="{StaticResource AccentActionBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="#FBFCFD">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- Branding Section -->
        <Border Grid.Row="0" Margin="20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Logo Display -->
                <Border Width="140" Height="140" 
                        CornerRadius="70" 
                        Background="White" 
                        BorderBrush="#F1F3F5" 
                        BorderThickness="3"
                        Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" Direction="-45" Opacity="0.12" ShadowDepth="8"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Fallback Text Logo -->
                        <TextBlock Text="GS" FontSize="{StaticResource FontSizeTitle}" FontWeight="Black" Foreground="{StaticResource AccentActionBrush}" 
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Visibility="{Binding CompanyLogo, Converter={StaticResource NullToVisibilityConverter}}"/>
                        
                        <!-- Actual Company Logo -->
                        <Ellipse Visibility="{Binding CompanyLogo, Converter={StaticResource NotNullToVisibilityConverter}}">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding CompanyLogo, Converter={StaticResource ByteArrayToImageConverter}}" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                </Border>

                <TextBlock Text="{Binding CompanyName}" 
                           FontSize="{StaticResource FontSizeTitle}" 
                           FontWeight="Black" 
                           Foreground="{StaticResource PrimaryHeaderBrush}" 
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                
                <TextBlock Text="نظام جينيوس لإدارة المخازن والمبيعات" 
                           FontSize="{StaticResource FontSizeNormal}" 
                           Foreground="#7F8C8D" 
                           HorizontalAlignment="Center" 
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Tasks Grid -->
        <UniformGrid Grid.Row="1" Columns="3" Margin="60,0,60,40">
            <Button Content="فاتورة مبيعات جديدة" 
                    Tag="IconSuccess" 
                    Style="{StaticResource TaskCardButtonStyle}" 
                    Command="{Binding NavigateToSalesCommand}"/>

            <Button Content="فاتورة مشتريات جديدة" 
                    Tag="IconPrint" 
                    Style="{StaticResource TaskCardButtonStyle}" 
                    Command="{Binding NavigateToPurchasesCommand}"/>

            <Button Content="إدارة المنتجات والمخزن" 
                    Tag="IconInformation" 
                    Style="{StaticResource TaskCardButtonStyle}" 
                    Command="{Binding NavigateToInventoryCommand}"/>

            <Button Content="التقارير والإحصائيات" 
                    Tag="IconActivity" 
                    Style="{StaticResource TaskCardButtonStyle}" 
                    Command="{Binding NavigateToReportsCommand}"/>

            <Button Content="إعدادات النظام" 
                    Tag="IconSettings" 
                    Style="{StaticResource TaskCardButtonStyle}" 
                    Command="{Binding NavigateToSettingsCommand}"/>

            <Border Margin="10" CornerRadius="20" BorderBrush="#EEE" BorderThickness="1">
                 <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.3">
                     <TextBlock Text="🔒" FontSize="{StaticResource FontSizeLarge}" HorizontalAlignment="Center"/>
                     <TextBlock Text="مهام إضافية" FontSize="{StaticResource FontSizeSmall}" HorizontalAlignment="Center"/>
                 </StackPanel>
            </Border>

        </UniformGrid>
    </Grid>
</UserControl>

