<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="MainBackgroundBrush" Color="#F0F4F8"/>

    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1A237E"/>

    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="PrimaryHeaderBrush" Color="#0D47A1"/>

    <SolidColorBrush x:Key="MainContentTextBrush" Color="#2D3436"/>

    <SolidColorBrush x:Key="SidebarTextBrush" Color="#E3F2FD"/>

    <SolidColorBrush x:Key="AccentActionBrush" Color="#2196F3"/>

    <SolidColorBrush x:Key="SelectionHighlightBrush" Color="#BBDEFB"/>

    <SolidColorBrush x:Key="StatusSuccessBrush" Color="#2ECC71"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="#E74C3C"/>
    <SolidColorBrush x:Key="StatusWarningBrush" Color="#F1C40F"/>
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#3498DB"/>
</ResourceDictionary>