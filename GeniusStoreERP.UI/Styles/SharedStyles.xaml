<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

        <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ConvertersDictionary.xaml"/>
        </ResourceDictionary.MergedDictionaries>

        <!-- Typography -->
        <FontFamily x:Key="MainFontFamily">Calibri</FontFamily>

        <!-- Standard Font Sizes (Centralized Control) -->
        <System:Double x:Key="FontSizeSmall" xmlns:System="clr-namespace:System;assembly=mscorlib">15</System:Double>
        <System:Double x:Key="FontSizeNormal" xmlns:System="clr-namespace:System;assembly=mscorlib">18</System:Double>
        <System:Double x:Key="FontSizeMedium" xmlns:System="clr-namespace:System;assembly=mscorlib">22</System:Double>
        <System:Double x:Key="FontSizeLarge" xmlns:System="clr-namespace:System;assembly=mscorlib">26</System:Double>
        <System:Double x:Key="FontSizeTitle" xmlns:System="clr-namespace:System;assembly=mscorlib">36</System:Double>

        <!-- Global Defaults -->
        <Style TargetType="Window">
                <Setter Property="FontFamily"
                        Value="{StaticResource MainFontFamily}"/>
        </Style>

        <Style TargetType="TextBlock">
                <Setter Property="FontFamily"
                        Value="{StaticResource MainFontFamily}"/>
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeNormal}"/>
        </Style>

        <Style TargetType="Control">
                <Setter Property="FontFamily"
                        Value="{StaticResource MainFontFamily}"/>
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeNormal}"/>
        </Style>

        <Style x:Key="MainHeaderStyle"
               TargetType="TextBlock">
                <Setter Property="FontFamily"
                        Value="{StaticResource MainFontFamily}"/>
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeTitle}"/>
                <Setter Property="FontWeight"
                        Value="ExtraBold"/>
                <Setter Property="Foreground"
                        Value="{StaticResource PrimaryHeaderBrush}"/>
                <Setter Property="Margin"
                        Value="0,0,0,5"/>
        </Style>

        <Style x:Key="SubHeaderStyle"
               TargetType="TextBlock">
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeMedium}"/>
                <Setter Property="Foreground"
                        Value="#7F8C8D"/>
                <Setter Property="Margin"
                        Value="0,0,0,20"/>
        </Style>

        <Style x:Key="FieldLabelStyle"
               TargetType="TextBlock">
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeMedium}"/>
                <Setter Property="FontWeight"
                        Value="SemiBold"/>
                <Setter Property="Foreground"
                        Value="{StaticResource MainContentTextBrush}"/>
                <Setter Property="Margin"
                        Value="0,0,0,8"/>
        </Style>


        <!-- Global Input Style (Border Container) -->
        <Style x:Key="UnifiedInputContainerStyle"
               TargetType="Border">
                <Setter Property="Background"
                        Value="#F8F9FA"/>
                <Setter Property="CornerRadius"
                        Value="8"/>
                <Setter Property="BorderBrush"
                        Value="#E0E0E0"/>
                <Setter Property="BorderThickness"
                        Value="1"/>
                <Setter Property="Margin"
                        Value="0,0,0,15"/>
                <Style.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                                <Setter Property="BorderBrush"
                                        Value="{StaticResource AccentActionBrush}"/>
                        </Trigger>
                </Style.Triggers>
        </Style>

        <!-- Global TextBox Style -->
        <Style x:Key="UnifiedTextBoxStyle"
               TargetType="TextBox">
                <Setter Property="Background"
                        Value="Transparent"/>
                <Setter Property="BorderThickness"
                        Value="0"/>
                <Setter Property="Padding"
                        Value="8,10"/>
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeNormal}"/>
                <Setter Property="VerticalContentAlignment"
                        Value="Center"/>
                <Setter Property="Foreground"
                        Value="{StaticResource MainContentTextBrush}"/>
        </Style>

        <!-- Global ComboBox Style -->
        <Style x:Key="UnifiedComboBoxStyle"
               TargetType="ComboBox">
                <Setter Property="Background"
                        Value="Transparent"/>
                <Setter Property="BorderThickness"
                        Value="0"/>
                <Setter Property="Padding"
                        Value="8,10"/>
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeNormal}"/>
                <Setter Property="VerticalContentAlignment"
                        Value="Center"/>
                <Setter Property="Foreground"
                        Value="{StaticResource MainContentTextBrush}"/>
        </Style>

        <!-- Global PasswordBox Style -->
        <Style x:Key="UnifiedPasswordBoxStyle"
               TargetType="PasswordBox">
                <Setter Property="Background"
                        Value="Transparent"/>
                <Setter Property="BorderThickness"
                        Value="0"/>
                <Setter Property="Padding"
                        Value="8,10"/>
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeNormal}"/>
                <Setter Property="VerticalContentAlignment"
                        Value="Center"/>
                <Setter Property="Foreground"
                        Value="{StaticResource MainContentTextBrush}"/>
        </Style>

        <!-- Global DatePicker Style -->
        <Style TargetType="DatePicker">
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeNormal}"/>
                <Setter Property="VerticalContentAlignment"
                        Value="Center"/>
                <Setter Property="Padding"
                        Value="2"/>
        </Style>

        <!-- Global Button Style -->
        <Style x:Key="UnifiedPrimaryButtonStyle"
               TargetType="Button">
                <Setter Property="Background"
                        Value="{StaticResource AccentActionBrush}"/>
                <Setter Property="Foreground"
                        Value="White"/>
                <Setter Property="Height"
                        Value="48"/>
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeNormal}"/>
                <Setter Property="FontWeight"
                        Value="SemiBold"/>
                <Setter Property="BorderThickness"
                        Value="0"/>
                <Setter Property="Cursor"
                        Value="Hand"/>
                <Setter Property="Template">
                        <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                        <Setter Property="Opacity"
                                                                Value="0.9"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed"
                                                         Value="True">
                                                        <Setter Property="Opacity"
                                                                Value="0.8"/>
                                                </Trigger>
                                        </ControlTemplate.Triggers>
                                </ControlTemplate>
                        </Setter.Value>
                </Setter>
        </Style>

        <!-- Global Secondary Button Style -->
        <Style x:Key="UnifiedSecondaryButtonStyle"
               TargetType="Button">
                <Setter Property="Background"
                        Value="#E9ECEF"/>
                <Setter Property="Foreground"
                        Value="#191970"/>
                <Setter Property="Height"
                        Value="48"/>
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeNormal}"/>
                <Setter Property="FontWeight"
                        Value="SemiBold"/>
                <Setter Property="BorderThickness"
                        Value="1"/>
                <Setter Property="BorderBrush"
                        Value="#6C757D"/>
                <Setter Property="Padding"
                        Value="10,5"/>
                <Setter Property="Cursor"
                        Value="Hand"/>
                <Setter Property="Template">
                        <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                        <Setter Property="Background"
                                                                Value="#D6D8DB"/>
                                                        <Setter Property="BorderBrush"
                                                                Value="#495057"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed"
                                                         Value="True">
                                                        <Setter Property="Background"
                                                                Value="#CED4DA"/>
                                                        <Setter Property="BorderBrush"
                                                                Value="#343A40"/>
                                                </Trigger>
                                        </ControlTemplate.Triggers>
                                </ControlTemplate>
                        </Setter.Value>
                </Setter>
        </Style>

        <!-- Global Icon Button Style -->
        <Style x:Key="UnifiedIconButtonStyle"
               TargetType="Button">
                <Setter Property="Background"
                        Value="Transparent"/>
                <Setter Property="BorderThickness"
                        Value="0"/>
                <Setter Property="Padding"
                        Value="5"/>
                <Setter Property="Cursor"
                        Value="Hand"/>
                <Setter Property="Template">
                        <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                        <Setter Property="Background"
                                                                Value="#F1F3F5"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed"
                                                         Value="True">
                                                        <Setter Property="Background"
                                                                Value="#E9ECEF"/>
                                                </Trigger>
                                        </ControlTemplate.Triggers>
                                </ControlTemplate>
                        </Setter.Value>
                </Setter>
        </Style>

        <!-- Global CheckBox Style -->
        <Style x:Key="UnifiedCheckBoxStyle"
               TargetType="CheckBox">
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeNormal}"/>
                <Setter Property="VerticalContentAlignment"
                        Value="Center"/>
                <Setter Property="Foreground"
                        Value="{StaticResource MainContentTextBrush}"/>
                <Setter Property="Cursor"
                        Value="Hand"/>
                <Setter Property="Template">
                        <Setter.Value>
                                <ControlTemplate TargetType="CheckBox">
                                        <BulletDecorator Background="Transparent">
                                                <BulletDecorator.Bullet>
                                                        <Border x:Name="BulletBorder"
                                                                Width="22"
                                                                Height="22"
                                                                Background="White"
                                                                BorderBrush="#E0E0E0"
                                                                BorderThickness="1"
                                                                CornerRadius="6">
                                                                <Viewbox x:Name="CheckIcon"
                                                                         Width="16"
                                                                         Height="16"
                                                                         Visibility="Collapsed">
                                                                        <Path Data="M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M10,17L5,12L6.41,10.59L10,14.17L17.59,6.58L19,8L10,17Z"
                                                                              Fill="{StaticResource AccentActionBrush}"
                                                                              Stretch="Uniform"/>
                                                                </Viewbox>
                                                        </Border>
                                                </BulletDecorator.Bullet>
                                                <ContentPresenter Margin="12,0,0,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"/>
                                        </BulletDecorator>
                                        <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked"
                                                         Value="True">
                                                        <Setter TargetName="CheckIcon"
                                                                Property="Visibility"
                                                                Value="Visible"/>
                                                        <Setter TargetName="BulletBorder"
                                                                Property="BorderBrush"
                                                                Value="{StaticResource AccentActionBrush}"/>
                                                        <Setter TargetName="BulletBorder"
                                                                Property="Background"
                                                                Value="#F0F4FF"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                        <Setter TargetName="BulletBorder"
                                                                Property="BorderBrush"
                                                                Value="{StaticResource AccentActionBrush}"/>
                                                </Trigger>
                                        </ControlTemplate.Triggers>
                                </ControlTemplate>
                        </Setter.Value>
                </Setter>
        </Style>

        <!-- Global Card Style -->
        <Style x:Key="UnifiedCardStyle"
               TargetType="Border">
                <Setter Property="Background"
                        Value="White"/>
                <Setter Property="CornerRadius"
                        Value="15"/>
                <Setter Property="Padding"
                        Value="25"/>
                <Setter Property="Effect">
                        <Setter.Value>
                                <DropShadowEffect BlurRadius="25"
                                                  Color="Black"
                                                  Opacity="0.1"
                                                  ShadowDepth="5"/>
                        </Setter.Value>
                </Setter>
        </Style>

        <DropShadowEffect x:Key="UnifiedCardStyle_ShadowOnly"
                          BlurRadius="15"
                          Color="Black"
                          Opacity="0.05"
                          ShadowDepth="2"/>

        <!-- Sidebar Nav Item Style (moved from MainView.xaml) -->
        <Style x:Key="SidebarNavItemStyle"
               TargetType="ListBoxItem">
                <Setter Property="Background"
                        Value="Transparent"/>
                <Setter Property="BorderThickness"
                        Value="0"/>
                <Setter Property="Padding"
                        Value="0"/>
                <Setter Property="Margin"
                        Value="8,2"/>
                <Setter Property="Cursor"
                        Value="Hand"/>
                <Setter Property="IsSelected"
                        Value="{Binding IsSelected, Mode=TwoWay}"/>
                <Setter Property="Template">
                        <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                        <StackPanel>
                                                <Border x:Name="ItemBorder"
                                                        Background="Transparent"
                                                        CornerRadius="10"
                                                        Padding="14,13">
                                                        <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding DataContext.SelectNavItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                              CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="28"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Icon (Vector Path) -->
                                                                <Viewbox Width="20"
                                                                         Height="20"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center">
                                                                        <Path x:Name="ItemIcon"
                                                                              Data="{Binding IconKey, Converter={StaticResource ResourceKeyToDataConverter}}"
                                                                              Fill="#9FA8DA"
                                                                              Stretch="Uniform"/>
                                                                </Viewbox>

                                                                <!-- Label -->
                                                                <TextBlock x:Name="ItemLabel"
                                                                           Grid.Column="1"
                                                                           Text="{Binding Title}"
                                                                           FontSize="18"
                                                                           FontWeight="SemiBold"
                                                                           FontFamily="{StaticResource MainFontFamily}"
                                                                           Foreground="#9FA8DA"
                                                                           Margin="12,0,0,0"
                                                                           VerticalAlignment="Center"/>

                                                                <!-- Expand/Collapse Icon -->
                                                                <Viewbox x:Name="ExpandIcon"
                                                                         Grid.Column="2"
                                                                         Width="12"
                                                                         Height="12"
                                                                         Visibility="Collapsed"
                                                                         RenderTransformOrigin="0.5,0.5">
                                                                        <Viewbox.RenderTransform>
                                                                                <RotateTransform Angle="0"/>
                                                                        </Viewbox.RenderTransform>
                                                                        <Path Data="M7,10L12,15L17,10H7Z"
                                                                              Fill="#9FA8DA"
                                                                              Stretch="Uniform"/>
                                                                </Viewbox>
                                                        </Grid>
                                                </Border>

                                                <!-- SubItems List -->
                                                <ItemsControl x:Name="SubItemsControl"
                                                              ItemsSource="{Binding SubItems}"
                                                              Visibility="Collapsed"
                                                              Margin="20,0,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                        <Border x:Name="SubItemBorder"
                                                                                Background="Transparent"
                                                                                CornerRadius="8"
                                                                                Padding="14,11"
                                                                                Margin="0,1"
                                                                                Cursor="Hand">
                                                                                <Border.InputBindings>
                                                                                        <MouseBinding MouseAction="LeftClick"
                                                                                                      Command="{Binding DataContext.SelectNavItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                                                      CommandParameter="{Binding}"/>
                                                                                </Border.InputBindings>
                                                                                <TextBlock x:Name="SubItemLabel"
                                                                                           Text="{Binding Title}"
                                                                                           FontSize="17"
                                                                                           FontWeight="Medium"
                                                                                           FontFamily="{StaticResource MainFontFamily}"
                                                                                           Foreground="#9FA8DA"
                                                                                           VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <DataTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver"
                                                                                         Value="True">
                                                                                        <Setter TargetName="SubItemBorder"
                                                                                                Property="Background"
                                                                                                Value="#263594"/>
                                                                                        <Setter TargetName="SubItemLabel"
                                                                                                Property="Foreground"
                                                                                                Value="White"/>
                                                                                </Trigger>
                                                                                <DataTrigger Binding="{Binding IsSelected}"
                                                                                             Value="True">
                                                                                        <Setter TargetName="SubItemBorder"
                                                                                                Property="Background"
                                                                                                Value="{StaticResource AccentActionBrush}"/>
                                                                                        <Setter TargetName="SubItemLabel"
                                                                                                Property="Foreground"
                                                                                                Value="White"/>
                                                                                </DataTrigger>
                                                                        </DataTemplate.Triggers>
                                                                </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                        </StackPanel>

                                        <ControlTemplate.Triggers>
                                                <!-- Main Item Mouse Over -->
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                        <Setter TargetName="ItemBorder"
                                                                Property="Background"
                                                                Value="#263594"/>
                                                        <Setter TargetName="ItemIcon"
                                                                Property="Fill"
                                                                Value="White"/>
                                                        <Setter TargetName="ItemLabel"
                                                                Property="Foreground"
                                                                Value="White"/>
                                                        <Setter TargetName="ExpandIcon"
                                                                Property="Visibility"
                                                                Value="Visible"/>
                                                </Trigger>

                                                <!-- If has subitems, show expand icon -->
                                                <DataTrigger Binding="{Binding SubItems.Count, Converter={StaticResource NumericToVisibilityConverter}}"
                                                             Value="Visible">
                                                        <Setter TargetName="ExpandIcon"
                                                                Property="Visibility"
                                                                Value="Visible"/>
                                                </DataTrigger>

                                                <!-- Expansion State -->
                                                <DataTrigger Binding="{Binding IsExpanded}"
                                                             Value="True">
                                                        <Setter TargetName="SubItemsControl"
                                                                Property="Visibility"
                                                                Value="Visible"/>
                                                        <Setter TargetName="ExpandIcon"
                                                                Property="RenderTransform">
                                                                <Setter.Value>
                                                                        <RotateTransform Angle="180"/>
                                                                </Setter.Value>
                                                        </Setter>
                                                </DataTrigger>

                                                <!-- Selection -->
                                                <DataTrigger Binding="{Binding IsSelected}"
                                                             Value="True">
                                                        <Setter TargetName="ItemBorder"
                                                                Property="Background"
                                                                Value="{StaticResource AccentActionBrush}"/>
                                                        <Setter TargetName="ItemIcon"
                                                                Property="Fill"
                                                                Value="White"/>
                                                        <Setter TargetName="ItemLabel"
                                                                Property="Foreground"
                                                                Value="White"/>
                                                </DataTrigger>
                                        </ControlTemplate.Triggers>
                                </ControlTemplate>
                        </Setter.Value>
                </Setter>
        </Style>

        <!-- Global DataGrid Styles -->
        <Style TargetType="DataGrid">
                <Setter Property="Background"
                        Value="White"/>
                <Setter Property="BorderThickness"
                        Value="0"/>
                <Setter Property="RowBackground"
                        Value="White"/>
                <Setter Property="AlternatingRowBackground"
                        Value="#F8F9FA"/>
                <Setter Property="GridLinesVisibility"
                        Value="None"/>
                <Setter Property="HeadersVisibility"
                        Value="Column"/>
                <Setter Property="AutoGenerateColumns"
                        Value="False"/>
                <Setter Property="CanUserAddRows"
                        Value="False"/>
                <Setter Property="CanUserDeleteRows"
                        Value="False"/>
                <Setter Property="IsReadOnly"
                        Value="True"/>
                <Setter Property="SelectionMode"
                        Value="Single"/>
                <Setter Property="ColumnHeaderHeight"
                        Value="50"/>
                <Setter Property="RowHeight"
                        Value="55"/>
                <Setter Property="FontSize"
                        Value="{StaticResource FontSizeNormal}"/>
                <Setter Property="FontFamily"
                        Value="{StaticResource MainFontFamily}"/>
        </Style>

        <!-- Global DataGridColumnHeader Style - Headers Centered -->
        <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background"
                        Value="#F1F3F5"/>
                <Setter Property="Foreground"
                        Value="{StaticResource MainContentTextBrush}"/>
                <Setter Property="FontWeight"
                        Value="SemiBold"/>
                <Setter Property="Padding"
                        Value="15,0"/>
                <Setter Property="BorderThickness"
                        Value="0,0,0,1"/>
                <Setter Property="BorderBrush"
                        Value="#E9ECEF"/>
                <Setter Property="Template">
                        <Setter.Value>
                                <ControlTemplate TargetType="DataGridColumnHeader">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center"/>
                                        </Border>
                                </ControlTemplate>
                        </Setter.Value>
                </Setter>
        </Style>

        <!-- Global DataGridRow Style -->
        <Style TargetType="DataGridRow">
                <Setter Property="BorderThickness"
                        Value="0,0,0,1"/>
                <Setter Property="BorderBrush"
                        Value="#F1F3F5"/>
                <Style.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                                <Setter Property="Background"
                                        Value="#E9ECEF"/>
                        </Trigger>
                        <Trigger Property="IsSelected"
                                 Value="True">
                                <Setter Property="Background"
                                        Value="{StaticResource SelectionHighlightBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource MainContentTextBrush}"/>
                        </Trigger>
                </Style.Triggers>
        </Style>

</ResourceDictionary>